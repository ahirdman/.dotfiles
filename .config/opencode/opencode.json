{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.3-codex",
  "autoupdate": true,
  "share": "disabled",
  "provider": {
    "github-copilot": {
      "models": {
        "gpt-5": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ]
          }
        }
      },
    },
  },
  "formatter": {
    "biome": {
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".json",
        ".md",
        ".mdx",
        ".css",
        ".scss",
        ".html"
      ]
    }
  },
  "agent": {
    "build": {
      "color": "#ea6962"
    },
    "azure-cli": {
      "description": "Azure CLI specialist for managing Azure resources. Automatically handles read operations but always asks for consent before any modifications, deletions, or operations that could incur costs.",
      "prompt": "{file:./prompts/azure-cli.md}",
      "model": "github-copilot/gpt-5.3-codex",
      "color": "#0078d4",
      "mode": "all",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "az account *": "allow",
          "az * list": "allow",
          "az * list *": "allow",
          "az * show": "allow",
          "az * show *": "allow",
          "az * get-*": "allow",
          "az find *": "allow",
          "az * --help": "allow",
          "az * --help *": "allow",
          "az * validate *": "allow",
          "az * what-if *": "allow"
        },
        "webfetch": "allow",
        "doom_loop": "ask",
        "external_directory": "allow"
      },
      "tools": {
        "bash": true,
        "edit": false,
        "write": false,
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "todowrite": true,
        "todoread": true,
        "webfetch": true,
        "question": true
      }
    },
    "plan": {
      "description": "Create a detailed plan for addressing complex tasks that require multiple steps or sub-tasks.",
      "prompt": "{file:./prompts/plan.md}",
      "model": "github-copilot/gpt-5.3-codex",
      "color": "#e78a4e",
      "permission": {
        "edit": "deny",
        "bash": {
          "git diff*": "allow",
          "git status*": "allow",
          "git *": "ask",
          "jq*": "allow",
        },
        "webfetch": "allow",
        "doom_loop": "ask",
        "external_directory": "allow",
      },
      "mode": "all",
      "tools": {
        "bash": true,
        "edit": false,
        "write": false,
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "patch": false,
        "todowrite": true,
        "todoread": true,
        "webfetch": true
      }
    },
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3"
  ],
  "mcp": {
    "figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "enabled": true,
      "environment": {
        "FIGMA_API_KEY": "{file:figma_api_key.txt}"
      }
    },
    "tavily": {
      "type": "remote",
      "url": "{file:tavily_mcp_url.txt}",
      "enabled": true,
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "headers": {
        "Authorization": "{file:github_pat.txt}"
      }
    },
  }
}
